<root main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <PipelineSequence>
      <!-- Compute path to goal while ticking fleet speed adjustment. -->
      <AdjustSpeedForFleet default_speed="0.5">
        <GoalUpdatedController>
          <ComputePathToPose goal="{goal}" path="{path}" planner_id="GridBased"/>
        </GoalUpdatedController>
      </AdjustSpeedForFleet>

      <!-- Fleet coordination wrapper -->
      <ReactiveSequence name="FleetCoordinatedFollow">
        <!-- Check for fleet conflicts -->
        <ReactiveFallback name="FleetYieldCheck">
          <!-- Inverter: if NO conflict, skip yield wait -->
          <Inverter>
            <CheckFleetConflict robot_id="{robot_id}"/>
          </Inverter>

          <!-- If conflict detected and we should yield -->
          <Sequence name="YieldSequence">
            <WaitForYieldClear robot_id="{robot_id}" peer_id="{conflict_peer}" timeout="15.0"/>
          </Sequence>
        </ReactiveFallback>

        <!-- Follow the computed path. Speed limits are published by the wrapper above. -->
        <FollowPath path="{path}" controller_id="FollowPath"/>
      </ReactiveSequence>
    </PipelineSequence>
  </BehaviorTree>
</root>
